---
<div id="cookie-banner" class="fixed bottom-10 left-6 right-6 md:left-10 md:right-auto md:max-w-sm z-[100] translate-y-[150%] transition-transform duration-700 ease-out">
  <div class="bg-zinc-950 border border-zinc-800 p-6 rounded-2xl shadow-2xl shadow-black border-glow">
    <div class="flex items-start gap-4 mb-4">
      <div class="w-10 h-10 rounded-full bg-mauve/10 flex items-center justify-center flex-shrink-0">
        <span class="text-xl">🍪</span>
      </div>
      <div>
        <h3 class="text-sm font-bold text-white mb-1 tracking-tight">Cookie Settings</h3>
        <p class="text-[11px] text-zinc-500 leading-relaxed">
          We use cookies to enhance your experience. Some are essential for the site to function, others help us improve. 
          <a href="/cookies" class="text-mauve hover:underline">Read more</a>.
        </p>
      </div>
    </div>
    <div class="flex gap-3">
      <button id="accept-cookies" class="flex-1 bg-white text-black text-[10px] font-black uppercase tracking-widest py-2.5 rounded-full hover:bg-mauve hover:text-white transition-all">
        Accept All
      </button>
      <button id="decline-cookies" class="flex-1 bg-zinc-900 text-zinc-400 text-[10px] font-bold uppercase tracking-widest py-2.5 rounded-full border border-zinc-800 hover:border-zinc-700 transition-all">
        Decline
      </button>
    </div>
  </div>
</div>

<script>
  const banner = document.getElementById('cookie-banner');
  const acceptBtn = document.getElementById('accept-cookies');
  const declineBtn = document.getElementById('decline-cookies');

  window.addEventListener('DOMContentLoaded', () => {
    const consent = localStorage.getItem('utask-cookie-consent');
    if (!consent) {
      setTimeout(() => {
        banner?.classList.remove('translate-y-[150%]');
      }, 2000);
    }
  });

  acceptBtn?.addEventListener('click', () => {
    localStorage.setItem('utask-cookie-consent', 'accepted');
    banner?.classList.add('translate-y-[150%]');
  });

  declineBtn?.addEventListener('click', () => {
    localStorage.setItem('utask-cookie-consent', 'declined');
    banner?.classList.add('translate-y-[150%]');
  });
</script>
