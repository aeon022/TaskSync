<section class="relative pt-32 pb-20 px-4 overflow-hidden">
  <div class="max-w-4xl mx-auto text-center relative">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-mauve/10 border border-mauve/20 text-mauve text-xs font-medium mb-8 animate-fade-in">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-mauve opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-mauve"></span>
      </span>
      v2.0 Elite Edition is live
    </div>
    
    <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6 gradient-text">
      The ultimate terminal <br/> task manager.
    </h1>
    
    <p class="text-lg md:text-xl text-zinc-400 mb-10 max-w-2xl mx-auto leading-relaxed">
      Synchronize Apple Reminders, Google Tasks, and Microsoft To Do seamlessly from your terminal. Headless sync, Pomodoro focus, and Raycast integration.
    </p>
    
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="#install" class="px-8 py-3 rounded-lg bg-white text-black font-bold hover:bg-zinc-200 transition-colors w-full sm:w-auto">
        Get Started
      </a>
      <a href="https://github.com/aeon022/TaskSync" class="px-8 py-3 rounded-lg bg-zinc-900 border border-zinc-800 text-white font-bold hover:bg-zinc-800 transition-colors w-full sm:w-auto">
        View on GitHub
      </a>
    </div>
  </div>
</section>
