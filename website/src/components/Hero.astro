---
---
<section class="relative pt-40 pb-20 px-6 overflow-hidden">
  <!-- Dynamic Hero Background Animation -->
  <div class="absolute inset-0 -z-10 pointer-events-none">
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-full max-w-7xl h-full flex justify-around opacity-20">
      <div class="terminal-line text-[80px] font-black text-mauve/20 select-none vertical-text">SYNCING</div>
      <div class="terminal-line text-[80px] font-black text-peach/20 select-none vertical-text delay-1000">DAEMON</div>
      <div class="terminal-line text-[80px] font-black text-blue/20 select-none vertical-text delay-2000">TASKS</div>
      <div class="terminal-line text-[80px] font-black text-mauve/20 select-none vertical-text delay-500">UTASK</div>
    </div>
  </div>

  <div class="max-w-4xl mx-auto text-center relative reveal">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-mauve/10 border border-mauve/20 text-mauve text-xs font-medium mb-8 animate-fade-in">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-mauve opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-mauve"></span>
      </span>
      v2.0 Elite Edition is live
    </div>
    
    <h1 class="text-6xl md:text-[5.5rem] font-bold tracking-tight mb-8 gradient-text leading-[1.1]">
      Task management <br/> built for the elite.
    </h1>
    
    <p class="text-lg md:text-2xl text-zinc-400 mb-12 max-w-2xl mx-auto leading-relaxed">
      A headless sync engine that bridges Apple Reminders, Google Tasks, and Microsoft To Do. Designed for speed, engineered for privacy.
    </p>
    
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 reveal delay-1">
      <a href="#install" class="px-10 py-4 rounded-full bg-white text-black font-black uppercase tracking-widest text-[11px] hover:bg-mauve hover:text-white transition-all scale-100 hover:scale-105 active:scale-95 shadow-xl shadow-white/5">
        Initialize Core
      </a>
      <a href="https://github.com/aeon022/TaskSync" target="_blank" class="px-10 py-4 rounded-full bg-[#0b0b0b] border border-zinc-800 text-zinc-400 font-bold uppercase tracking-widest text-[10px] hover:text-white hover:border-zinc-700 transition-all flex items-center gap-2 group">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:rotate-12 transition-transform"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.28 1.15-.28 2.35 0 3.5-.73 1.02-1.08 2.25-1 3.5 0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        GitHub Source
      </a>
    </div>
  </div>
</section>

<style>
  .vertical-text {
    writing-mode: vertical-rl;
    text-orientation: mixed;
    letter-spacing: 0.5em;
    animation: slide-v 40s linear infinite;
    mask-image: linear-gradient(to bottom, transparent, black 10%, black 90%, transparent);
  }

  @keyframes slide-v {
    from { transform: translateY(-50%); }
    to { transform: translateY(50%); }
  }

  .delay-1000 { animation-delay: 5s; }
  .delay-2000 { animation-delay: 12s; }
  .delay-500 { animation-delay: 20s; }
</style>
