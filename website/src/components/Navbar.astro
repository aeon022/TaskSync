---
---
<header class="fixed top-6 left-0 right-0 z-50 px-6 pointer-events-none">
  <nav 
    id="navbar" 
    class="max-w-fit mx-auto px-4 py-2 rounded-full border border-zinc-800/50 bg-[#050505]/40 backdrop-blur-xl shadow-2xl shadow-black/50 pointer-events-auto transition-all duration-500 ease-out flex items-center gap-8"
  >
    <!-- Logo -->
    <a href="#" class="flex items-center gap-2.5 pl-2 group">
      <div class="w-7 h-7 rounded-lg bg-mauve/20 flex items-center justify-center border border-mauve/30 group-hover:bg-mauve/30 transition-all">
        <span class="text-mauve text-[10px] font-bold italic">u</span>
      </div>
      <span class="text-sm font-bold tracking-tighter text-white">utask<span class="text-mauve">.</span></span>
    </a>
    
    <!-- Navigation Links -->
    <div class="hidden md:flex items-center gap-6 text-[10px] uppercase tracking-[0.2em] font-bold text-zinc-500" id="nav-links">
      <a href="#terminal" class="nav-link relative hover:text-white transition-colors py-1">
        Interface
        <span class="underline-bar absolute bottom-0 left-0 w-0 h-[1px] bg-mauve transition-all duration-300"></span>
      </a>
      <a href="#features" class="nav-link relative hover:text-white transition-colors py-1">
        Features
        <span class="underline-bar absolute bottom-0 left-0 w-0 h-[1px] bg-mauve transition-all duration-300"></span>
      </a>
      <a href="#commands" class="nav-link relative hover:text-white transition-colors py-1">
        Commands
        <span class="underline-bar absolute bottom-0 left-0 w-0 h-[1px] bg-mauve transition-all duration-300"></span>
      </a>
      <a href="#install" class="nav-link relative hover:text-white transition-colors py-1">
        Install
        <span class="underline-bar absolute bottom-0 left-0 w-0 h-[1px] bg-mauve transition-all duration-300"></span>
      </a>
      <a href="https://buy.polar.sh/polar_cl_9nID64E6BrctC1A2WeHbdVUeaBNOq5TbIXiyA3JInoV" target="_blank" class="relative hover:text-white transition-colors py-1 text-peach group/support">
        Support ☕
        <span class="absolute bottom-0 left-0 w-0 h-[1px] bg-peach transition-all duration-300 group-hover/support:w-full"></span>
      </a>
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-4 pr-1">
      <a href="https://github.com/aeon022/TaskSync" target="_blank" class="text-zinc-500 hover:text-white transition-all hover:scale-110">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.28 1.15-.28 2.35 0 3.5-.73 1.02-1.08 2.25-1 3.5 0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
      </a>
      <div class="h-4 w-[1px] bg-zinc-800"></div>
      <a href="#install" class="bg-white text-black text-[9px] uppercase tracking-widest font-black px-5 py-2 rounded-full hover:bg-mauve hover:text-white transition-all shadow-lg shadow-white/5">
        Get Access
      </a>
    </div>
  </nav>
</header>

<style>
  .nav-link.active {
    color: white;
  }
  .nav-link.active .underline-bar {
    width: 100%;
  }
</style>

<script>
  const nav = document.getElementById('navbar');
  const links = document.querySelectorAll('.nav-link');
  const sections = ['terminal', 'features', 'commands', 'install'];

  window.addEventListener('scroll', () => {
    // Navbar Shrink Effect
    if (window.scrollY > 50) {
      nav?.classList.add('px-3', 'py-1.5', 'border-mauve/20', 'bg-[#050505]/80');
      nav?.classList.remove('px-4', 'py-2', 'border-zinc-800/50', 'bg-[#050505]/40');
    } else {
      nav?.classList.remove('px-3', 'py-1.5', 'border-mauve/20', 'bg-[#050505]/80');
      nav?.classList.add('px-4', 'py-2', 'border-zinc-800/50', 'bg-[#050505]/40');
    }

    // Scrollspy Logic
    let current = "";
    sections.forEach((section) => {
      const element = document.getElementById(section);
      if (element) {
        const sectionTop = element.offsetTop;
        if (window.scrollY >= sectionTop - 250) {
          current = section;
        }
      }
    });

    links.forEach((link) => {
      link.classList.remove('active');
      if (link.getAttribute('href') === `#${current}`) {
        link.classList.add('active');
      }
    });
  });
</script>
